{
  "version": 1,
  "adapters": {
    "mode": "command",
    "executor_profile": "auto",
    "reviewer_profile": "codex",
    "profiles": {
      "glm": {
        "provider": "opencode-go",
        "model": "opencode-go/glm-5.2",
        "command": "gjc -p --model opencode-go/glm-5.2 --no-session @{prompt_file}",
        "tmux_command": "gjc --model opencode-go/glm-5.2",
        "purpose": "Default GJC executor using OpenCode Go GLM 5.2 for implementation and blocker repair tasks."
      },
      "codex-executor": {
        "provider": "codex",
        "model": "codex-default",
        "command": "codex exec --dangerously-bypass-approvals-and-sandbox -",
        "purpose": "Fallback executor when GLM is unavailable, quota/rate limited, times out, or exits nonzero."
      },
      "codex": {
        "provider": "codex",
        "model": "codex-default",
        "command": "codex exec --sandbox read-only -",
        "purpose": "Strict independent reviewer. Keep final PASS/REVIEW_BLOCKED authority here."
      },
      "gjc-rpc": {
        "provider": "gjc",
        "protocol": "jsonl-rpc",
        "command": "gjc --mode rpc",
        "purpose": "Experimental typed JSONL GJC adapter. CfC sends prompt frames and consumes completion/state frames instead of scraping a tmux transcript."
      }
    },
    "auto": {
      "default_executor_profile": "glm",
      "complex_executor_profile": "glm",
      "complex_keywords": [
        "architecture",
        "architect",
        "multi-file",
        "refactor",
        "migration",
        "security",
        "auth",
        "async",
        "tmux",
        "state",
        "concurrency",
        "race",
        "database",
        "schema",
        "protocol",
        "아키텍처",
        "여러 파일",
        "리팩터",
        "마이그레이션",
        "보안",
        "인증",
        "비동기",
        "상태",
        "동시성",
        "복잡"
      ]
    },
    "fallbacks": {
      "glm": [
        "codex-executor"
      ]
    }
  },
  "verification": {
    "commands": [
      "git diff --check"
    ]
  }
}
